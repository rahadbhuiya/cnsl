{
  "authlog_path": "/var/log/auth.log",
  "tcpdump_enabled": false,

  "thresholds": {
    "fails_window_sec": 60,
    "fails_threshold": 8,
    "unique_users_threshold": 4,
    "success_after_fails_threshold": 5,
    "incident_cooldown_sec": 120
  },

  "actions": {
    "dry_run": true,
    "block_duration_sec": 900,
    "block_backend": "iptables",
    "chain": "INPUT"
  },

  "allowlist": [
    "127.0.0.1",
    "::1"
  ],

  "store": {
    "db_path": "./cnsl_state.db"
  },

  "logging": {
    "json_log_path": "./cnsl.jsonl",
    "console_verbose": true,
    "log_net_hints": false
  },

  "dashboard": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8765
  },

  "notifications": {
    "min_severity": "MEDIUM",
    "telegram": {
      "enabled": false,
      "bot_token": "YOUR_BOT_TOKEN",
      "chat_id": "YOUR_CHAT_ID"
    },
    "discord": {
      "enabled": false,
      "webhook_url": ""
    },
    "slack": {
      "enabled": false,
      "webhook_url": ""
    }
  },

  "geoip": {
    "mmdb_path": null
  },

  "auth": {
    "enabled": false
  },

  "redis": {
    "enabled": false
  },

  "threat_intel": {
    "abuseipdb": {
      "enabled": false
    }
  },

  "behavioral_baseline": {
    "enabled": true,
    "min_observations": 10
  },

  "fim": {
    "enabled": false
  },

  "ml": {
    "enabled": false
  },

  "honeypot": {
    "enabled": false
  },

  "asset_inventory": {
    "enabled": true
  },

  "log_sources": {
    "nginx":  null,
    "apache": null,
    "mysql":  null,
    "ufw":    null,
    "syslog": null
  },

  "reporting": {
    "output_dir": "./reports"
  },

  "queue": {
    "maxsize": 10000
  }
}